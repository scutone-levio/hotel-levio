// Prisma schema for the Hotel Reservation application.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model RoomTypeDefinition {
  id            String            @id @default(cuid())
  slug          String            @unique
  name          String
  description   String
  capacity      Int
  beds          Int
  basePrice     Int
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  rooms         Room[]
  subcategories RoomSubcategory[]
  bookings      Booking[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model RoomSubcategory {
  id              String             @id @default(cuid())
  name            String
  roomTypeId      String
  roomType        RoomTypeDefinition @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  basePrice       Int
  fromPriceCents  Int                @default(0)
  hasWeekendRates Boolean            @default(false)
  featured        Boolean            @default(false)
  isActive        Boolean            @default(true)
  rooms           Room[]
  bookings        Booking[]
  images          SubcategoryImage[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([roomTypeId, name])
  @@index([roomTypeId])
}

model SubcategoryImage {
  id            String          @id @default(cuid())
  subcategory   RoomSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  subcategoryId String
  url           String
  key           String?
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())

  @@index([subcategoryId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  province      String?
  postalCode    String?
  country       String?   @default("CA")
  role          Role      @default(CUSTOMER)
  bookings      Booking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Room {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  description   String
  roomTypeId    String
  roomType      RoomTypeDefinition @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  basePrice     Int
  capacity      Int                @default(2)
  beds          Int                @default(1)
  floor         Int?
  roomNumber    String             @unique
  subcategory   RoomSubcategory?   @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  subcategoryId String?
  isCatalog     Boolean            @default(false)
  archivedAt    DateTime?
  amenities     Amenity[]          @relation("RoomAmenities")
  images        RoomImage[]
  blackouts     RoomBlackout[]
  priceRules    RoomPriceRule[]
  bookings      Booking[]
  nearbyPlaces  NearbyPlace[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([roomTypeId])
  @@index([floor])
  @@index([subcategoryId])
  @@index([archivedAt])
}

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String?
  rooms     Room[]   @relation("RoomAmenities")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomImage {
  id        String   @id @default(cuid())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  url       String
  key       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([roomId])
}

model RoomBlackout {
  id        String   @id @default(cuid())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@index([roomId])
}

model RoomPriceRule {
  id        String   @id @default(cuid())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  dayOfWeek Int
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, dayOfWeek])
  @@index([roomId])
}

model NearbyPlace {
  id       String @id @default(cuid())
  room     Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId   String
  name     String
  category String
  distance String

  @@unique([roomId, name])
  @@index([roomId])
}

model Booking {
  id                        String              @id @default(cuid())
  user                      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                    String
  room                      Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId                    String
  roomTypeId                String?
  roomType                  RoomTypeDefinition? @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)
  subcategory               RoomSubcategory?    @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  subcategoryId             String?
  checkIn                   DateTime            @db.Date
  checkOut                  DateTime            @db.Date
  guests                    Int                 @default(1)
  totalPrice                Int
  status                    BookingStatus       @default(PENDING)
  stripeSessionId           String?
  dateChangeStripePaymentId String?             @unique
  guestName                 String?
  guestEmail                String?
  guestPhone                String?
  specialRequests           String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  @@index([roomId])
  @@index([userId])
  @@index([subcategoryId])
  @@index([roomTypeId])
}
